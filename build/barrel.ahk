/************************************************************************
 * This script compiles `all.ahk` by scanning the lints/ directory for 
 * .ahk files
 ***********************************************************************/

#Warn VarUnset, StdOut
#Warn Unreachable, StdOut

#Include "./errshim.ahk"

A_WorkingDir := A_WorkingDir "/../lints"

stdout := FileOpen("*", "w")

banner := Format("
(
    /**
     * This file is automatically generated. It is not meant for manual editing.
     * Generated: {1}
     */

)", FormatTime(A_Now))

if FileExist("all.ahk") {
    stdout.WriteLine("Overwriting existing 'all.ahk' file")
}

barrelFile := FileOpen("all.ahk", "w")

count := 0
classes := []

barrelFile.WriteLine(banner)

loop files "*.ahk", "fr" {
    if A_LoopFileName == "all.ahk"
        continue

    ; Assume that class name is the same as the file name
    className := SubStr(A_LoopFileName, 1, -4)

    barrelFile.WriteLine(Format("#Import `"{1}`" { {2} }", A_LoopFileFullPath, className))
    classes.Push(className)
    count++
}

barrelFile.WriteLine("export global ALL_LINTS := [")
for className in classes
    barrelFile.WriteLine("    " className ",")
barrelFile.WriteLine("]")

barrelFile.Close()

stdout.WriteLine(Format("Built barrel with {1} lint files", count))

stdout.Close()
ExitApp(0)