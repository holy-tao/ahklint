{
    "entry": "ahklint.ahk",
    "interpreter": {
        "version": "2.1-alpha.30",
        "bitness": 64
    },
    "exe": {
        "name": "ahklint",
        "company": "Tao Beloney",
        "version": "0.1.0.0",
        "subsystem": "console",
        "copyright": "Copyright 2026 Tao Beloney",
        "description": "AutoHotkey v2/v2.1 linter",
        "icon": "assets/emoji-mag.ico"
    },
    "resources": {
        "extra": [
            { "name": "LICENSE", "type": "RT_RCDATA", "path": "LICENSE" }
        ]
  },
  "scripts": {
    "pre-bundle": [
            ["${AHK}", "/ErrorStdOut=UTF-8", "./build/barrel.ahk"],
            ["${AHK}", "/ErrorStdOut=UTF-8", "/Validate", "${AHKBUILD_ENTRY}"]
        ],
        "post-bundle": []
  }
}